generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CommercialStatus {
  available
  occupied
  blocked
  out_of_service
}

enum CleaningStatus {
  clean
  dirty
  cleaning
  inspection
}

enum MaintenanceStatus {
  ok
  pending
  in_progress
  out_of_service
}

enum UserStatus {
  active
  inactive
}

enum ReservationStatus {
  pending
  confirmed
  assigned
  in_house
  cancelled
  no_show
  completed
}

enum StayStatus {
  in_house
  checked_out
}

enum FolioStatus {
  open
  closed
}

enum ChargeKind {
  lodging
  extra
  minibar
  laundry
  food
  beverage
  parking
  adjustment
}

enum PaymentMethod {
  cash
  card
  transfer
  account
  usd
  other
}

enum OccupantAgeCategory {
  adult
  child
}

enum HousekeepingTaskStatus {
  pending
  in_progress
  inspection
  completed
  cancelled
}

enum HousekeepingPriority {
  normal
  arrival_today
  urgent
}

enum MaintenanceTicketStatus {
  pending
  in_progress
  resolved
  cancelled
}

enum MaintenancePriority {
  low
  medium
  high
  urgent
}

enum CashSessionStatus {
  open
  closed
}

enum CashMovementKind {
  payment
  expense
  adjustment
}

enum InvoiceStatus {
  draft
  pending_afip
  authorized
  rejected
  cancelled
}

enum InvoiceType {
  invoice
  credit_note
  debit_note
  internal_receipt
}

model Hotel {
  id        String   @id @default(uuid())
  name      String
  legalName String
  taxId     String?
  timezone  String   @default("America/Asuncion")
  currency  String   @default("ARS")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                User[]
  roomTypes            RoomType[]
  rooms                Room[]
  guests               Guest[]
  reservations         Reservation[]
  reservationOccupants ReservationOccupant[]
  stays                Stay[]
  folios               Folio[]
  charges              Charge[]
  payments             Payment[]
  housekeepingTasks    HousekeepingTask[]
  maintenanceTickets   MaintenanceTicket[]
  cashSessions         CashSession[]
  cashMovements        CashMovement[]
  invoices             Invoice[]
  auditLogs            AuditLog[]
}

model User {
  id           String     @id @default(uuid())
  hotelId      String
  roleId       String
  name         String
  email        String     @unique
  passwordHash String
  status       UserStatus @default(active)
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  hotel                      Hotel               @relation(fields: [hotelId], references: [id])
  role                       Role                @relation(fields: [roleId], references: [id])
  auditLogs                  AuditLog[]
  assignedHousekeepingTasks  HousekeepingTask[]  @relation("HousekeepingAssignedTo")
  assignedMaintenanceTickets MaintenanceTicket[] @relation("MaintenanceAssignedTo")
  openedCashSessions         CashSession[]       @relation("CashSessionOpenedBy")
  closedCashSessions         CashSession[]       @relation("CashSessionClosedBy")
}

model Role {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  permissions RolePermission[]
}

model Permission {
  id          String   @id @default(uuid())
  code        String   @unique
  description String
  createdAt   DateTime @default(now())

  roles RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model RoomType {
  id           String   @id @default(uuid())
  hotelId      String
  code         String
  name         String
  baseCapacity Int
  maxCapacity  Int
  description  String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  hotel        Hotel         @relation(fields: [hotelId], references: [id])
  rooms        Room[]
  reservations Reservation[]

  @@unique([hotelId, code])
}

model Room {
  id                String            @id @default(uuid())
  hotelId           String
  roomTypeId        String
  number            String
  floor             String?
  block             String?
  capacity          Int
  notes             String?
  active            Boolean           @default(true)
  commercialStatus  CommercialStatus  @default(available)
  cleaningStatus    CleaningStatus    @default(clean)
  maintenanceStatus MaintenanceStatus @default(ok)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  hotel                Hotel               @relation(fields: [hotelId], references: [id])
  roomType             RoomType            @relation(fields: [roomTypeId], references: [id])
  assignedReservations Reservation[]
  stays                Stay[]
  folios               Folio[]
  housekeepingTasks    HousekeepingTask[]
  maintenanceTickets   MaintenanceTicket[]

  @@unique([hotelId, number])
  @@index([hotelId, commercialStatus])
  @@index([hotelId, cleaningStatus])
  @@index([hotelId, maintenanceStatus])
}

model Guest {
  id             String   @id @default(uuid())
  hotelId        String
  firstName      String
  lastName       String
  documentType   String?
  documentNumber String?
  email          String?
  phone          String?
  nationality    String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  hotel        Hotel         @relation(fields: [hotelId], references: [id])
  reservations Reservation[]

  @@index([hotelId, lastName, firstName])
  @@index([hotelId, documentNumber])
}

model Reservation {
  id               String            @id @default(uuid())
  hotelId          String
  guestId          String
  roomTypeId       String
  assignedRoomId   String?
  code             String
  status           ReservationStatus @default(pending)
  source           String            @default("direct")
  checkInDate      DateTime
  checkOutDate     DateTime
  adults           Int               @default(1)
  children         Int               @default(0)
  currency         String            @default("ARS")
  nightlyRate      Decimal?          @db.Decimal(12, 2)
  totalAmount      Decimal?          @db.Decimal(12, 2)
  depositAmount    Decimal?          @db.Decimal(12, 2)
  depositPaid      Boolean           @default(false)
  depositMethod    PaymentMethod?
  depositReference String?
  notes            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  hotel        Hotel                 @relation(fields: [hotelId], references: [id])
  guest        Guest                 @relation(fields: [guestId], references: [id])
  roomType     RoomType              @relation(fields: [roomTypeId], references: [id])
  assignedRoom Room?                 @relation(fields: [assignedRoomId], references: [id])
  stay         Stay?
  folio        Folio?
  occupants    ReservationOccupant[]

  @@unique([hotelId, code])
  @@index([hotelId, status])
  @@index([hotelId, checkInDate, checkOutDate])
  @@index([hotelId, assignedRoomId])
}

model ReservationOccupant {
  id             String              @id @default(uuid())
  hotelId        String
  reservationId  String
  firstName      String
  lastName       String
  documentType   String?
  documentNumber String?
  phone          String?
  nationality    String?
  ageCategory    OccupantAgeCategory @default(adult)
  primary        Boolean             @default(false)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  hotel       Hotel       @relation(fields: [hotelId], references: [id])
  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([hotelId, reservationId])
  @@index([hotelId, documentNumber])
}

model Stay {
  id            String     @id @default(uuid())
  hotelId       String
  reservationId String     @unique
  roomId        String
  status        StayStatus @default(in_house)
  checkedInAt   DateTime   @default(now())
  checkedOutAt  DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  hotel       Hotel       @relation(fields: [hotelId], references: [id])
  reservation Reservation @relation(fields: [reservationId], references: [id])
  room        Room        @relation(fields: [roomId], references: [id])
  folio       Folio?

  @@index([hotelId, status])
  @@index([hotelId, roomId])
}

model Folio {
  id            String      @id @default(uuid())
  hotelId       String
  reservationId String      @unique
  stayId        String?     @unique
  roomId        String
  status        FolioStatus @default(open)
  currency      String      @default("ARS")
  openedAt      DateTime    @default(now())
  closedAt      DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  hotel       Hotel       @relation(fields: [hotelId], references: [id])
  reservation Reservation @relation(fields: [reservationId], references: [id])
  stay        Stay?       @relation(fields: [stayId], references: [id])
  room        Room        @relation(fields: [roomId], references: [id])
  charges     Charge[]
  payments    Payment[]
  invoices    Invoice[]

  @@index([hotelId, status])
  @@index([hotelId, roomId])
}

model Charge {
  id          String     @id @default(uuid())
  hotelId     String
  folioId     String
  kind        ChargeKind
  description String
  quantity    Int        @default(1)
  unitAmount  Decimal    @db.Decimal(12, 2)
  totalAmount Decimal    @db.Decimal(12, 2)
  postedAt    DateTime   @default(now())
  voidedAt    DateTime?
  createdAt   DateTime   @default(now())

  hotel Hotel @relation(fields: [hotelId], references: [id])
  folio Folio @relation(fields: [folioId], references: [id])

  @@index([hotelId, folioId])
}

model Payment {
  id            String        @id @default(uuid())
  hotelId       String
  folioId       String
  method        PaymentMethod
  currency      String        @default("ARS")
  amount        Decimal       @db.Decimal(12, 2)
  reference     String?
  cashSessionId String?
  paidAt        DateTime      @default(now())
  voidedAt      DateTime?
  createdAt     DateTime      @default(now())

  hotel       Hotel        @relation(fields: [hotelId], references: [id])
  folio       Folio        @relation(fields: [folioId], references: [id])
  cashSession CashSession? @relation(fields: [cashSessionId], references: [id])

  @@index([hotelId, folioId])
  @@index([hotelId, cashSessionId])
}

model HousekeepingTask {
  id              String                 @id @default(uuid())
  hotelId         String
  roomId          String
  assignedToId    String?
  status          HousekeepingTaskStatus @default(pending)
  priority        HousekeepingPriority   @default(normal)
  source          String                 @default("manual")
  notes           String?
  pauseReason     String?
  rejectionReason String?
  checklistJson   Json?
  suppliesJson    Json?
  issueNotes      String?
  lostFoundNotes  String?
  startedAt       DateTime?
  pausedAt        DateTime?
  finishedAt      DateTime?
  inspectedAt     DateTime?
  rejectedAt      DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  hotel      Hotel @relation(fields: [hotelId], references: [id])
  room       Room  @relation(fields: [roomId], references: [id])
  assignedTo User? @relation("HousekeepingAssignedTo", fields: [assignedToId], references: [id])

  @@index([hotelId, status])
  @@index([hotelId, priority])
  @@index([hotelId, roomId])
}

model MaintenanceTicket {
  id           String                  @id @default(uuid())
  hotelId      String
  roomId       String?
  assignedToId String?
  title        String
  description  String?
  priority     MaintenancePriority     @default(medium)
  status       MaintenanceTicketStatus @default(pending)
  outOfService Boolean                 @default(false)
  startedAt    DateTime?
  resolvedAt   DateTime?
  cancelledAt  DateTime?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  hotel      Hotel @relation(fields: [hotelId], references: [id])
  room       Room? @relation(fields: [roomId], references: [id])
  assignedTo User? @relation("MaintenanceAssignedTo", fields: [assignedToId], references: [id])

  @@index([hotelId, status])
  @@index([hotelId, roomId])
}

model CashSession {
  id            String            @id @default(uuid())
  hotelId       String
  openedById    String
  closedById    String?
  status        CashSessionStatus @default(open)
  openingAmount Decimal           @default(0) @db.Decimal(12, 2)
  countedCash   Decimal?          @db.Decimal(12, 2)
  notes         String?
  openedAt      DateTime          @default(now())
  closedAt      DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  hotel     Hotel          @relation(fields: [hotelId], references: [id])
  openedBy  User           @relation("CashSessionOpenedBy", fields: [openedById], references: [id])
  closedBy  User?          @relation("CashSessionClosedBy", fields: [closedById], references: [id])
  payments  Payment[]
  movements CashMovement[]

  @@index([hotelId, status])
  @@index([hotelId, openedAt])
}

model CashMovement {
  id            String           @id @default(uuid())
  hotelId       String
  cashSessionId String
  kind          CashMovementKind
  method        PaymentMethod    @default(cash)
  amount        Decimal          @db.Decimal(12, 2)
  description   String
  createdAt     DateTime         @default(now())
  voidedAt      DateTime?

  hotel       Hotel       @relation(fields: [hotelId], references: [id])
  cashSession CashSession @relation(fields: [cashSessionId], references: [id])

  @@index([hotelId, cashSessionId])
}

model Invoice {
  id          String        @id @default(uuid())
  hotelId     String
  folioId     String
  type        InvoiceType   @default(invoice)
  status      InvoiceStatus @default(draft)
  pointOfSale String?
  number      String?
  cae         String?
  caeDueDate  DateTime?
  subtotal    Decimal       @default(0) @db.Decimal(12, 2)
  taxAmount   Decimal       @default(0) @db.Decimal(12, 2)
  totalAmount Decimal       @default(0) @db.Decimal(12, 2)
  afipError   String?
  issuedAt    DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  hotel Hotel @relation(fields: [hotelId], references: [id])
  folio Folio @relation(fields: [folioId], references: [id])

  @@index([hotelId, status])
  @@index([hotelId, folioId])
}

model AuditLog {
  id        String   @id @default(uuid())
  hotelId   String?
  userId    String?
  action    String
  entity    String
  entityId  String?
  before    Json?
  after     Json?
  reason    String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  hotel Hotel? @relation(fields: [hotelId], references: [id])
  user  User?  @relation(fields: [userId], references: [id])

  @@index([hotelId, entity, entityId])
  @@index([createdAt])
}
